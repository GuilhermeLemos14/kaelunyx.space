---
// /src/components/BaseHead.astro
import "@/styles/global.css";
import site from "@/data/site";
import { socialsJsonLd } from "@/data/socials";

export interface Props {
	title?: string;
	description?: string;
	noindex?: boolean;
	image?: string;
	imageAlt?: string;
}

const {
	title,
	description,
	noindex = false,
	image = "/thumbnail.png",
	imageAlt = "Black dog with snow on its snout in a snowy landscape, with the text 'Kaelunyx Space' on the left.",
} = Astro.props;

const {
	title: siteTitle,
	description: siteDescription,
	author: authorName,
	twitterHandle,
	dateCreated,
	locale,
} = site;

const absoluteImage = new URL(image, Astro.site).href;
const canonicalURL = new URL(Astro.url.pathname, Astro.site);
---

<!-- Global Metadata -->
<meta charset="utf-8" />
<meta name="viewport" content="width=device-width, initial-scale=1.0" />
<meta name="color-scheme" content="dark" />
<meta name="theme-color" content="#98949c" />
<meta name="author" content={authorName} />
<link
	rel="alternate"
	type="application/rss+xml"
	title={siteTitle}
	href={new URL("rss.xml", Astro.site)}
/>
<meta name="robots" content={noindex ? "noindex, nofollow" : "index, follow"} />
<link rel="sitemap" href="/sitemap-index.xml" />
<meta name="generator" content={Astro.generator} />

<!-- Canonical URL -->
<link rel="canonical" href={canonicalURL} />

<!-- Title and Description -->
<title>{title ? `${siteTitle} - ${title}` : siteTitle}</title>
<meta name="title" content={title ? `${siteTitle} - ${title}` : siteTitle} />
<meta name="description" content={description || siteDescription} />

<!-- Open Graph / Facebook -->
<meta property="og:site_name" content={siteTitle} />
<meta property="og:locale" content={locale} />
<meta property="og:type" content="website" />
<meta property="og:url" content={Astro.url} />
<meta
	property="og:title"
	content={title ? `${siteTitle} - ${title}` : siteTitle}
/>
<meta property="og:description" content={description || siteDescription} />

<!-- Open Graph Image -->
<meta property="og:image" content={absoluteImage} />
<meta property="og:image:type" content="image/png" />
<meta property="og:image:width" content="1200" />
<meta property="og:image:height" content="630" />
<meta property="og:image:alt" content={imageAlt} />

<!-- Twitter -->
<meta property="twitter:card" content="summary_large_image" />
<meta property="twitter:site" content={twitterHandle} />
<meta property="twitter:url" content={Astro.url} />
<meta
	property="twitter:title"
	content={title ? `${siteTitle} - ${title}` : siteTitle}
/>
<meta property="twitter:description" content={description || siteDescription} />
<meta property="twitter:image" content={absoluteImage} />
<meta property="twitter:image:alt" content={imageAlt} />

<!-- Icons -->
<link rel="icon" href="/favicon.svg" type="image/svg+xml" />
<link rel="shortcut icon" href="/favicon.ico" type="image/x-icon" />
<link rel="icon" href="/favicon.ico" sizes="any" />
<link rel="icon" href="/favicon.png" type="image/png" />
<link rel="apple-touch-icon" href="/profile.png" />
<!-- <link rel="manifest" href="/site.webmanifest" /> -->

<!-- Google Fonts -->
<link rel="preconnect" href="https://fonts.googleapis.com" />
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
<link
	href="https://fonts.googleapis.com/css2?family=Atkinson+Hyperlegible:wght@400;700&display=swap"
	rel="stylesheet"
/>

<!-- Schema.org -->
<script
	is:inline
	type="application/ld+json"
	set:html={JSON.stringify({
		"@context": "https://schema.org",
		"@type": "ProfilePage",
		inLanguage: "en-CA",
		dateCreated: dateCreated,
		dateModified: new Date().toISOString(),
		mainEntity: {
			"@type": "Person",
			"@id": `${Astro.site}/#person`,
			name: authorName,
			alternateName: "Kaelunyx",
			description: description,
			image: `${Astro.site}/profile.png`,
			sameAs: socialsJsonLd,
			url: Astro.site,
			knowsLanguage: ["pt-BR", "en-CA"],
		},
	})}
/>
