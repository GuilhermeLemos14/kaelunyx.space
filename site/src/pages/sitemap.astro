---
import Layout from "../layouts/Layout.astro";

import "../styles/style.css";
import "../styles/pages/sitemap.css";

const title = "Sitemap — Kaelunyx Space";
const description = "A sitemap of all the pages on Kaelunyx Space.";
const url = "https://kaelunyx.space/sitemap/";
const header = {
	title: "Sitemap",
	subtitle:
		"A sitemap of all the pages on Kaelunyx Space.<br />Better visualization on desktop.",
};
---

<Layout {title} {description} {url} {header}>
	<section>
		<h2>Pages on Kaelunyx Space</h2>
		<ul id="pages">
			<li>
				<a href="/"
					>Portal
					<div class="description">
						The main page of Kaelunyx Space
					</div></a
				>
			</li>
			<li>
				<a href="/communities/"
					>Communities
					<div class="description">
						Communities where I'm active and I'd recommend you to
						join
					</div></a
				>
				<ul class="pages">
					<li>
						<a href="/communities/"
							>Index
							<div class="description">
								Some of the communities where Kaelunyx is active
							</div></a
						>
					</li>
					<li>
						<a href="/communities/form.html"
							>Form
							<div class="description">
								Form to submit/recommend communities to Kaelunyx
							</div></a
						>
					</li>
				</ul>
			</li>
			<li>
				<a href="/sitemap/"
					>Sitemap
					<div class="description">
						A sitemap of all the pages on Kaelunyx Space
					</div></a
				>
			</li>
			<li>
				<a href="/webrings/"
					>Webrings
					<div class="description">
						A collection of webrings that I'm part of
					</div></a
				>
			</li>
		</ul>
	</section>
	<section>
		<h2>Other Pages</h2>
		<ul id="other">
			<li>
				<a
					rel="noopener"
					href="https://art.kaelunyx.space"
					target="_blank"
					>Art
					<div class="description">My digital art portfolio</div>
				</a>
			</li>
			<li>
				<a
					rel="noopener"
					href="https://blog.kaelunyx.space"
					target="_blank"
					>Blog
					<div class="description">
						My thoughts on coding and more
					</div>
				</a>
			</li>
			<li>
				<a
					rel="noopener"
					href="https://me.kaelunyx.space"
					target="_blank"
					>Me
					<div class="description">Learn more about me</div>
				</a>
			</li>
			<li>
				<a
					rel="noopener"
					href="https://portfolio.kaelunyx.space"
					target="_blank"
					>Portfolio
					<div class="description">
						My coding projects and experience
					</div>
				</a>
			</li>
		</ul>
	</section>
</Layout>
