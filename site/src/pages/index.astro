---
import Layout from "../layouts/Layout.astro";

import "../styles/style.css";
import "../styles/pages/index.css";

const title = "Kaelunyx Space";
const description =
	"Kaelunyx, a young Fullstack Web Developer wandering through unseen layers of the web.";
const url = "https://kaelunyx.space/";
const header = {
	title: "Kaelunyx Space",
	subtitle: "Portal to Other Dimensions",
};
const nonav = true;
---

<Layout {title} {description} {url} {header} {nonav}>
	<p>
		Welcome to Kaelunyx Space, a portal to other dimensions of the web.
		Explore my art, blog, and more as I wander through unseen layers of the
		web.
	</p>
	<div id="nav-wrapper">
		<nav aria-label="Main navigation">
			<ul>
				<li>
					<a href="https://art.kaelunyx.space">Art</a>
				</li>
				<li>
					<a href="https://blog.kaelunyx.space">Blog </a>
				</li>
				<li>
					<a href="https://me.kaelunyx.space">Me</a>
				</li>
				<li>
					<a href="https://portfolio.kaelunyx.space">Portfolio</a>
				</li>
			</ul>
			<ul>
				<li><a href="/communities/">Communities</a></li>
				<li><a href="/sitemap/">Sitemap</a></li>
				<li><a href="/webrings/">Webrings</a></li>
			</ul>
		</nav>
	</div>
</Layout>
