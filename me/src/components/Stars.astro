---
import "@/styles/stars.scss";

const backStars = Array.from({ length: 40 });
const frontStars = Array.from({ length: 10 });
---

<button
	id="toggle-stars-btn"
	class="custom-btn px-3 py-2 fixed top-4 right-4 z-20 motion-reduce:hidden noscript:hidden"
	aria-hidden="true">Toggle Stars</button
>

<div
	class="stars stars--back motion-reduce:hidden noscript:hidden"
	aria-hidden="true">
	{backStars.map(() => <div class="star" />)}
</div>

<div
	class="stars stars--front motion-reduce:hidden noscript:hidden"
	aria-hidden="true">
	{frontStars.map(() => <div class="star" />)}
</div>

<script is:inline aria-hidden="true">
	const params = new URLSearchParams(location.search);
	const starsEnabled = params.get("stars") !== "off";

	if (!starsEnabled) {
		document.querySelectorAll(".page-link").forEach((element) => {
			const url = new URL(
				element.getAttribute("href") || "",
				window.location.origin,
			);
			url.searchParams.set("stars", "off");
			element.setAttribute("href", url.toString());
		});

		document.querySelectorAll(".stars").forEach((star) => {
			star.remove();
		});
	}

	const toggleButton = document.getElementById("toggle-stars-btn");
	if (toggleButton) {
		toggleButton.addEventListener("click", () => {
			const currentUrl = new URL(window.location.href);
			if (!starsEnabled) {
				currentUrl.searchParams.delete("stars");
			} else {
				currentUrl.searchParams.set("stars", "off");
			}
			window.location.href = currentUrl.toString();
		});
	}
</script>
