---
export interface Props {
	lang: string;
	link: string;
	pronouns: string;
}

const { lang, link, pronouns } = Astro.props;
---

<a
	class="text-cosmic-adaptive-blue font-semibold no-underline hover:underline focus-visible:underline"
	href={"http://" + lang + ".pronouns.page/" + link}
	target="_blank"
	rel="noopener noreferrer">{pronouns}</a
>
